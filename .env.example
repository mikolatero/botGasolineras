APP_ENV=development
LOG_LEVEL=INFO
OUTBOUND_HTTP_TRUST_ENV=false
# En Docker se sobreescribe a /etc/ssl/certs/ca-certificates.crt
OUTBOUND_HTTP_CA_BUNDLE=
TELEGRAM_BOT_TOKEN=replace-me
DATABASE_URL=mysql+asyncmy://gasbot:gasbot@mysql:3306/gasbot
MINETUR_API_URL=https://sedeaplicaciones.minetur.gob.es/ServiciosRESTCarburantes/PreciosCarburantes/EstacionesTerrestres
MINETUR_API_TIMEOUT_SECONDS=30
MINETUR_API_RETRIES=3
SYNC_INTERVAL_MINUTES=30
RUN_SYNC_ON_STARTUP=true
SEARCH_RESULT_PAGE_SIZE=5
WATCHLIST_PAGE_SIZE=5
RATE_LIMIT_WINDOW_SECONDS=3
RATE_LIMIT_MAX_EVENTS=6
BOT_DEFAULT_PARSE_MODE=HTML
TIMEZONE=Europe/Madrid
